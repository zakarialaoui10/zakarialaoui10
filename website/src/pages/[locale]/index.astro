---
// src/pages/[locale]/index.astro
import BaseLayout from '@layouts/BaseLayout.astro';

// 1. Generate standard routes for your supported locales
export function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'ar' } },
  ];
}

const { locale } = Astro.params;

// 2. Define your content vocabulary mapping 
const dictionary = {
  en: {
    title: "Developer Portfolio",
    heroTitle: "Building Seamless Interactive Web Applications",
    aboutTitle: "About Me",
    projectsTitle: "Recent Deployments",
    navHome: "Home",
    navAbout: "About",
    navProjects: "Projects"
  },
  ar: {
    title: "ملف المطور الشخصي",
    heroTitle: "بناء تطبيقات ويب تفاعلية وسلسة",
    aboutTitle: "من أنا",
    projectsTitle: "المشاريع الحالية",
    navHome: "الرئيسية",
    navAbout: "تفاصيل",
    navProjects: "المشاريع"
  }
};

// Fallback to English safety defaults if localization gets lost
const ui = dictionary[locale as keyof typeof dictionary] || dictionary.en;
---

<BaseLayout title={ui.title} description="Interactive 3D Graphics Platform">
  
  <!-- Setup Header Navigation elements -->
  <strong slot="nav-logo">Dev.Core</strong>
  
  <ul slot="nav-links" class="nav-links-list">
    <li><a href={`/${locale}#home-view`} class="is-active">{ui.navHome}</a></li>
    <li><a href={`/${locale}#about-view`}>{ui.navAbout}</a></li>
    <li><a href={`/${locale}#projects-view`}>{ui.navProjects}</a></li>
  </ul>

  <!-- Main View Component Blocks -->
  <section id="home-view" class="portfolio-section section-hero">
    <div class="layout-container">
      <h1>{ui.heroTitle}</h1>
    </div>
  </section>

  <section id="about-view" class="portfolio-section section-about">
    <div class="layout-container">
      <h2>{ui.aboutTitle}</h2>
    </div>
  </section>

  <section id="projects-view" class="portfolio-section section-projects">
    <div class="layout-container">
      <h2>{ui.projectsTitle}</h2>
    </div>
  </section>

</BaseLayout>