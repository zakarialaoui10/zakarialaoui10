---
// src/layouts/BaseLayout.astro
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Dynamic Adaptive Platform" } = Astro.props;
const { currentLocale } = Astro;

// Compute writing alignment dynamically
const isRTL = currentLocale === 'ar';
const dir = isRTL ? 'rtl' : 'ltr';
---

<!DOCTYPE html>
<html lang={currentLocale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <style is:global>
      @import url("@styles/root.css");
      
    
      body.search-modal-open {
        overflow: hidden;
      }

      .nav-header {
        position: fixed;
        top: 0;
        inset-inline-start: 0; /* Replaces left: 0 / right: 0 seamlessly */
        width: 100%;
        height: var(--nav-height);
        z-index: 100;
        display: flex;
        align-items: center;
        background-color: transparent;
        color: var(--text-nav);
        transition: background-color var(--transition-speed) var(--transition-timing), color var(--transition-speed) var(--transition-timing);
      }

      .nav-header.is-scrolled {
        background-color: var(--bg-nav);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--border-nav);
      }

      .layout-container {
        width: 100%;
        max-width: 1200px;
        margin-inline: auto; /* Handles horizontal centering automatically */
        padding-inline: 1.5rem; /* Dual directional padding axis */
      }

      .flex-row-between {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
      }

      .nav-controls {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .nav-menu-wrapper {
        position: absolute;
        top: var(--nav-height);
        inset-inline-start: 0;
        width: 100%;
        background-color: var(--bg-nav);
        border-bottom: 1px solid var(--border-nav);
        padding: 2rem 1.5rem;
        display: none; 
        z-index: 99;
      }

      .nav-menu-wrapper.is-active {
        display: block;
      }

      .nav-links-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        list-style: none;
        width: 100%;
        position: relative;
      }

      .nav-links-list a {
        color: inherit;
        text-decoration: none;
        font-weight: 500;
        display: block;
        width: 100%;
        transition: color var(--transition-speed) var(--transition-timing);
      }

      .nav-links-list a.is-active {
        color: var(--accent-color); 
      }

      .nav-indicator-slider {
        display: none;
        position: absolute;
        bottom: -6px;
        inset-inline-start: 0;
        height: 2px;
        background-color: var(--accent-color);
        border-radius: 2px;
        pointer-events: none;
        will-change: transform, width;
        transition: transform var(--transition-speed) var(--transition-timing), width var(--transition-speed) var(--transition-timing);
      }

      .nav-icon-btn {
        background: transparent;
        border: none;
        color: var(--text-nav);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 6px;
        transition: color var(--transition-speed) var(--transition-timing), background-color var(--transition-speed) var(--transition-timing);
      }

      .nav-icon-btn:hover {
        background-color: rgba(125, 125, 125, 0.1);
      }

      .nav-icon-btn .icon-sun { display: block; }
      .nav-icon-btn .icon-moon { display: none; }

      [data-theme="dark"] .nav-icon-btn .icon-sun { display: none; }
      [data-theme="dark"] .nav-icon-btn .icon-moon { display: block; }

      .search-bar-trigger {
        background-color: var(--bg-search-trigger);
        border: 1px solid var(--border-card);
        color: var(--text-search-placeholder);
        font-family: var(--font-sans);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        padding-inline: 0.75rem;
        height: 38px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.875rem;
        user-select: none;
        transition: border-color var(--transition-speed) var(--transition-timing), background-color var(--transition-speed) var(--transition-timing);
      }

      .search-bar-trigger:hover {
        border-color: rgba(125, 125, 125, 0.25);
      }

      .search-bar-trigger-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .search-bar-trigger-hint {
        display: none;
        font-weight: 400;
      }

      .search-bar-trigger-kbd {
        display: none;
        font-family: inherit;
        font-size: 0.75rem;
        background-color: var(--kbd-bg);
        border: 1px solid var(--kbd-border);
        color: var(--text-search-placeholder);
        padding-block: 0.15rem;
        padding-inline: 0.4rem;
        border-radius: 4px;
      }

      .search-modal-overlay {
        position: fixed;
        top: 0;
        inset-inline-start: 0;
        width: 100%;
        height: 100%;
        background-color: var(--bg-overlay);
        backdrop-filter: blur(4px);
        z-index: 200;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-block: 4rem;
        padding-inline: 1rem;
        opacity: 0;
        pointer-events: none;
        will-change: opacity;
        transition: opacity var(--transition-speed) var(--transition-timing);
      }

      .search-modal-overlay.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .search-modal-card {
        background-color: var(--bg-modal);
        width: 100%;
        max-width: 550px;
        border-radius: 12px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        border: 1px solid var(--border-card);
        overflow: hidden;
        transform: translateY(-20px);
        will-change: transform;
        transition: transform var(--transition-speed) var(--transition-timing);
      }

      .search-modal-overlay.is-open .search-modal-card {
        transform: translateY(0);
      }

      .search-modal-header {
        display: flex;
        align-items: center;
        padding-block: 1rem;
        padding-inline: 1.25rem;
        border-bottom: 1px solid var(--border-card);
        gap: 0.75rem;
      }

      .search-input-container {
        flex: 1;
        position: relative;
        display: flex;
        align-items: center;
      }

      /* Using native modern logical definitions for safe input layouts */
      .search-input-field {
        width: 100%;
        background-color: var(--bg-search-input);
        border: 1px solid var(--border-card);
        color: inherit;
        font-family: inherit;
        font-size: 1rem;
        padding-block: 0.65rem;
        padding-inline-start: 2.25rem;
        padding-inline-end: 1rem;
        border-radius: 8px;
        outline: none;
        transition: border-color var(--transition-speed) var(--transition-timing);
      }

      .search-field-icon {
        position: absolute;
        inset-inline-start: 0.75rem; 
        color: var(--text-modal-muted);
        pointer-events: none;
      }

      .search-close-instructions {
        font-size: 0.75rem;
        color: var(--text-modal-muted);
        border: 1px solid var(--border-card);
        padding-block: 0.2rem;
        padding-inline: 0.4rem;
        border-radius: 4px;
        background-color: var(--bg-search-input);
        display: none;
        user-select: none;
      }

      .search-modal-body {
        padding: 1.5rem;
        min-height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-modal-muted);
        font-size: 0.95rem;
      }

      .burger-trigger {
        background: transparent;
        border: none;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        width: 24px;
        height: 18px;
        z-index: 101;
        margin-inline-start: 0.25rem;
      }

      .burger-bar {
        width: 100%;
        height: 2px;
        background-color: var(--text-nav);
        transition: transform var(--transition-speed) var(--transition-timing), opacity var(--transition-speed) var(--transition-timing);
      }

      .burger-trigger.is-active .burger-bar:nth-child(1) { transform: translateY(8px) rotate(45deg); }
      .burger-trigger.is-active .burger-bar:nth-child(2) { opacity: 0; }
      .burger-trigger.is-active .burger-bar:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

      .portfolio-section {
        min-height: 100vh;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-block: calc(var(--nav-height) + 2rem) 4rem;
        transition: background-color var(--transition-speed) var(--transition-timing), color var(--transition-speed) var(--transition-timing);
      }

      .section-hero { background-color: var(--bg-hero); color: var(--text-hero); }
      .section-about { background-color: var(--bg-about); color: var(--text-about); }
      .section-projects { background-color: var(--bg-projects); color: var(--text-projects); }

      .flex-split {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        width: 100%;
      }

      .flex-split-child {
        flex: 1 1 0%;
        width: 100%;
      }

      .flex-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        width: 100%;
      }

      .flex-grid-item {
        flex: 1 1 100%;
        background-color: var(--bg-card);
        border: 1px solid var(--border-card);
        padding: 2.5rem;
        border-radius: 8px;
      }

      .language-switcher-link {
        font-weight: 700;
        text-decoration: none;
        color: var(--accent-color);
        padding-block: 0.35rem;
        padding-inline: 0.65rem;
        border: 1px solid var(--accent-color);
        border-radius: 4px;
        font-size: 0.85rem;
        text-transform: uppercase;
      }

      @media (min-width: 768px) {
        .layout-container { padding-inline: 3rem; }
        .portfolio-section { padding-block: var(--nav-height) 0; }
        .search-modal-overlay { padding-block: 8rem; }
        .search-close-instructions { display: block; }
        .search-bar-trigger-hint { display: block; }
        .search-bar-trigger-kbd { display: block; }

        .nav-menu-wrapper {
          position: static;
          display: block;
          padding: 0;
          background-color: transparent;
          border-bottom: none;
          width: auto;
        }

        .nav-links-list {
          flex-direction: row;
          gap: 2rem;
          margin-inline-end: 1rem;
        }

        .nav-indicator-slider { display: block; }
        .burger-trigger { display: none; }
        .flex-split { flex-direction: row; align-items: center; }
        .flex-grid-item { flex: 1 1 calc(50% - 1rem); }
      }

      @media (min-width: 1024px) {
        .flex-grid-item { flex: 1 1 calc(33.333% - 1.34rem); }
      }
    </style>

    <script is:inline>
      // Sync dark mode configuration safely inline to stop visual flashes
      const currentPersistedTheme = () => {
        const localChoice = localStorage.getItem('theme');
        if (localChoice) return localChoice;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      document.documentElement.setAttribute('data-theme', currentPersistedTheme());
    </script>
  </head>
  <body>
    
    <header id="portfolio-navbar" class="nav-header">
      <div class="layout-container flex-row-between">
        <slot name="nav-logo"><strong>Core.</strong></slot>
        
        <div class="nav-controls">
          <div id="mobile-menu-drawer" class="nav-menu-wrapper">
            <slot name="nav-links" />
          </div>

          <button id="search-modal-open-btn" class="search-bar-trigger" aria-label="Open global search">
            <div class="search-bar-trigger-left">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              <span class="search-bar-trigger-hint">Search...</span>
            </div>
            <kbd class="search-bar-trigger-kbd">Ctrl K</kbd>
          </button>

          <button id="theme-switcher-btn" class="nav-icon-btn" aria-label="Theme view toggle">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
          </button>
          
          <!-- Explicit dynamic language alternate toggle -->
          {currentLocale === 'en' ? (
            <a href="/ar" class="language-switcher-link">العربية</a>
          ) : (
            <a href="/" class="language-switcher-link">English</a>
          )}

          <button id="burger-menu-toggle" class="burger-trigger" aria-label="Toggle navigation interface" aria-expanded="false">
            <span class="burger-bar"></span>
            <span class="burger-bar"></span>
            <span class="burger-bar"></span>
          </button>
        </div>
      </div>
    </header>

    <div id="search-overlay" class="search-modal-overlay" role="dialog" aria-modal="true">
      <div class="search-modal-card">
        <div class="search-modal-header">
          <div class="search-input-container">
            <svg class="search-field-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="search" id="modal-search-field" class="search-input-field" placeholder="Search parameters..." autocomplete="off" />
          </div>
          <kbd class="search-close-instructions">ESC</kbd>
          <button id="search-modal-close-btn" class="nav-icon-btn" aria-label="Close layout overlay">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <div class="search-modal-body">
          <div id="search-results-root">Type to explore...</div>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <script>
      const header = document.getElementById('portfolio-navbar');
      const burgerBtn = document.getElementById('burger-menu-toggle');
      const navMenu = document.getElementById('mobile-menu-drawer');
      const themeToggleBtn = document.getElementById('theme-switcher-btn');
      const movingSlider = document.getElementById('moving-nav-slider');

      // Modal Setup
      const searchOpenBtn = document.getElementById('search-modal-open-btn');
      const searchCloseBtn = document.getElementById('search-modal-close-btn');
      const searchOverlay = document.getElementById('search-overlay');
      const searchInputField = document.getElementById('modal-search-field') as HTMLInputElement | null;

      const openSearchModal = () => {
        searchOverlay?.classList.add('is-open');
        document.body.classList.add('search-modal-open');
        setTimeout(() => searchInputField?.focus(), 50);
      };

      const closeSearchModal = () => {
        searchOverlay?.classList.remove('is-open');
        document.body.classList.remove('search-modal-open');
      };

      searchOpenBtn?.addEventListener('click', openSearchModal);
      searchCloseBtn?.addEventListener('click', closeSearchModal);
      searchOverlay?.addEventListener('click', (e) => {
        if (e.target === searchOverlay) closeSearchModal();
      });

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && searchOverlay?.classList.contains('is-open')) closeSearchModal();
        if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          searchOverlay?.classList.contains('is-open') ? closeSearchModal() : openSearchModal();
        }
      });

      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) header?.classList.add('is-scrolled');
        else header?.classList.remove('is-scrolled');
      });

      const toggleMobileMenu = () => {
        const isOpen = burgerBtn?.classList.toggle('is-active');
        navMenu?.classList.toggle('is-active');
        burgerBtn?.setAttribute('aria-expanded', String(isOpen));
      };

      burgerBtn?.addEventListener('click', toggleMobileMenu);

      themeToggleBtn?.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', nextTheme);
        localStorage.setItem('theme', nextTheme);
        
        // Let position adjust slightly if slider calculation shifts across theme switches
        setTimeout(() => {
          const currentActiveLink = document.querySelector('#mobile-menu-drawer a.is-active') as HTMLElement;
          if (currentActiveLink && window.innerWidth >= 768) updateSliderPosition(currentActiveLink);
        }, 50);
      });

      const navLinks = document.querySelectorAll('#mobile-menu-drawer a');
      const targetSections = document.querySelectorAll('#home-view, #about-view, #projects-view');

      const updateSliderPosition = (activeLink: HTMLElement | null) => {
        if (!movingSlider) return;
        if (activeLink && window.innerWidth >= 768) {
          const container = activeLink.closest('.nav-links-list');
          if (container) {
            const linkRect = activeLink.getBoundingClientRect();
            const containerRect = container.getBoundingClientRect();
            
            const isRtl = document.documentElement.getAttribute('dir') === 'rtl';
            
            // Computes translation offsets relative to the layout boundary matrix context
            const translationValue = isRtl 
              ? containerRect.right - linkRect.right 
              : linkRect.left - containerRect.left;

            movingSlider.style.width = `${linkRect.width}px`;
            movingSlider.style.transform = `translateX(${isRtl ? -translationValue : translationValue}px)`;
            movingSlider.style.opacity = '1';
            return;
          }
        }
        movingSlider.style.opacity = '0';
      };

      const observerOptions = {
        root: null,
        rootMargin: '-40% 0px -50% 0px',
        threshold: 0
      };

      const observerCallback = (entries: IntersectionObserverEntry[]) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const sectionId = entry.target.getAttribute('id');
            let matchedLink: HTMLElement | null = null;

            navLinks.forEach((link) => {
              const hrefAttribute = link.getAttribute('href');
              // Validate hash strings against localized path configurations correctly
              if (hrefAttribute && hrefAttribute.endsWith(`#${sectionId}`)) {
                link.classList.add('is-active');
                matchedLink = link as HTMLElement;
              } else {
                link.classList.remove('is-active');
              }
            });

            if (matchedLink) updateSliderPosition(matchedLink);
          }
        });
      };

      const sectionObserver = new IntersectionObserver(observerCallback, observerOptions);
      targetSections.forEach((section) => sectionObserver.observe(section));

      window.addEventListener('resize', () => {
        const currentActiveLink = document.querySelector('#mobile-menu-drawer a.is-active') as HTMLElement;
        updateSliderPosition(currentActiveLink);
      });
    </script>
  </body>
</html>